{
  "version": 6,
  "configurePresets": [
    {
      "name": "vcpkg-base",
      "hidden": true,
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/.vcpkg/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_OVERLAY_TRIPLETS": "${sourceDir}/cmake/vcpkg-triplets"
      }
    },
    {
      "name": "vcpkg-debug-base",
      "hidden": true,
      "inherits": "vcpkg-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "vcpkg-release-base",
      "hidden": true,
      "inherits": "vcpkg-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "macos-arm64-debug",
      "displayName": "macOS arm64 Debug",
      "inherits": "vcpkg-debug-base",
      "binaryDir": "${sourceDir}/build/macos-arm64-debug",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      },
      "cacheVariables": {
        "CMAKE_OSX_ARCHITECTURES": "arm64",
        "VCPKG_TARGET_TRIPLET": "arm64-osx-flowfield"
      }
    },
    {
      "name": "macos-arm64-release",
      "displayName": "macOS arm64 Release",
      "inherits": "vcpkg-release-base",
      "binaryDir": "${sourceDir}/build/macos-arm64-release",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      },
      "cacheVariables": {
        "CMAKE_OSX_ARCHITECTURES": "arm64",
        "VCPKG_TARGET_TRIPLET": "arm64-osx-flowfield"
      }
    },
    {
      "name": "macos-x64-release",
      "displayName": "macOS x64 Release",
      "inherits": "vcpkg-release-base",
      "binaryDir": "${sourceDir}/build/macos-x64-release",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      },
      "cacheVariables": {
        "CMAKE_OSX_ARCHITECTURES": "x86_64",
        "VCPKG_TARGET_TRIPLET": "x64-osx-flowfield"
      }
    },
    {
      "name": "linux-x64-release",
      "displayName": "Linux x64 Release",
      "inherits": "vcpkg-release-base",
      "binaryDir": "${sourceDir}/build/linux-x64-release",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-linux-flowfield"
      }
    },
    {
      "name": "linux-arm64-release",
      "displayName": "Linux arm64 Release",
      "inherits": "vcpkg-release-base",
      "binaryDir": "${sourceDir}/build/linux-arm64-release",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "arm64-linux-flowfield"
      }
    },
    {
      "name": "windows-x64-release",
      "displayName": "Windows x64 Release",
      "inherits": "vcpkg-release-base",
      "binaryDir": "${sourceDir}/build/windows-x64-release",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-windows-flowfield"
      }
    },
    {
      "name": "windows-arm64-release",
      "displayName": "Windows arm64 Release",
      "inherits": "vcpkg-release-base",
      "binaryDir": "${sourceDir}/build/windows-arm64-release",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "arm64-windows-flowfield"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "macos-arm64-debug",
      "configurePreset": "macos-arm64-debug"
    },
    {
      "name": "macos-arm64-release",
      "configurePreset": "macos-arm64-release"
    },
    {
      "name": "macos-x64-release",
      "configurePreset": "macos-x64-release"
    },
    {
      "name": "linux-x64-release",
      "configurePreset": "linux-x64-release"
    },
    {
      "name": "linux-arm64-release",
      "configurePreset": "linux-arm64-release"
    },
    {
      "name": "windows-x64-release",
      "configurePreset": "windows-x64-release"
    },
    {
      "name": "windows-arm64-release",
      "configurePreset": "windows-arm64-release"
    }
  ]
}
